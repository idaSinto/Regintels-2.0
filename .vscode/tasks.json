{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-next-dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [
        {
          "owner": "next",
          "severity": "info",
          "pattern": {
            "regexp": ".*",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "> .*",
            "endsPattern": "ready - started server on .*"
          }
        }
      ]
    }
  ]
}
